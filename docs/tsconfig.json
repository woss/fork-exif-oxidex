{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ESNext", "DOM"],
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": ["vitepress/client"]
  },
  "include": [".vitepress/**/*"],
  "exclude": ["node_modules", ".vitepress/dist"]
}
