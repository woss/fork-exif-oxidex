# CodeMachine directories (only exclude memory and artifacts, keep prompts and templates)
.codemachine/memory/
.codemachine/artifacts/

# Node modules
node_modules

# Environment variables
.env
.env.local
.env.*.local

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode
.idea
*.swp
*.swo
*~


# Rust build artifacts
/target/
**/*.rs.bk
*.pdb

# Cargo lock file (keep for binary crates, ignore for libraries)
# Since this is both, we keep Cargo.lock
# Cargo.lock

# Fuzzing artifacts (keep named corpus seed files like *.pdf, *.mp4, exclude fuzzer-generated hash files)
fuzz/target/
fuzz/artifacts/
# Exclude all files in corpus directories
fuzz/corpus/*/*
# But keep named seed files (*.pdf, *.mp4, etc.)
!fuzz/corpus/*/*.pdf
!fuzz/corpus/*/*.mp4
!fuzz/corpus/*/*.jpg
!fuzz/corpus/*/*.png

# Benchmark outputs
benches/target/

# Claude Code config
.claude/

# Helper scripts and temporary files
generate_tags.py
additional_tags.txt
exif_additional.txt
new_tags.txt

# MCP config (if not needed in repo)
.mcp.json

# Codemachine temporary/draft files
.codemachine/inputs/*.3.md
.codemachine/inputs/*.4md
